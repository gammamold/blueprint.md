# Scraper env — copy to scraper.env and fill in your values
# The scraper runs standalone, separate from the Next.js app.

# GitHub personal access token
# Create one at: https://github.com/settings/tokens
# Only needs "public_repo" read scope (or no scope for public repos)
GITHUB_TOKEN=ghp_your_token_here

# Anthropic API key — used to classify files with Claude Haiku
ANTHROPIC_API_KEY=sk-ant-your_key_here

# Supabase — needed for import-scraped.mjs (not for the scraper itself)
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_KEY=your_service_role_key_here
